# ==============================================
# LocalGrid - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values
# The app works in DEMO MODE without any API keys

# DataForSEO API (Required for real scans)
# Sign up at https://app.dataforseo.com/register
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Maps API Key (Required for map display)
# Get from https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google OAuth (Required for GBP management)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# OpenAI (Optional - for AI review reply generation)
OPENAI_API_KEY=
